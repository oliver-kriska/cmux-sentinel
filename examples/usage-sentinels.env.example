# ~/.config/cmux/usage-sentinels.env
# The two dedicated "sentinel" workspace UUIDs that carry the usage bars.
# Get them after creating the workspaces (see README step 1):
#   cmux workspace list                                   # find the refs
#   cmux sidebar-state --workspace workspace:<N> | grep '^tab='
SENTINEL_5H=REPLACE_WITH_5H_SENTINEL_UUID
SENTINEL_7D=REPLACE_WITH_7D_SENTINEL_UUID
